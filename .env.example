# Copy this to .env and fill in your values

# Windows VM IP (run `ipconfig` inside the VM, look for VMware/Parallels adapter)
VM_IP=192.168.64.2
VM_PORT=5000

# Trading settings
SYMBOL=XAUUSD
TIMEFRAME=5          # M5
VOLUME=0.01          # lot size
POLL_INTERVAL=60     # seconds between signal checks (match your candle TF)
MONITOR_INTERVAL=5   # seconds between position P&L checks
MAX_POSITIONS=1      # max concurrent open positions (0 = unlimited)

# Stochastic
STOCH_K=14
STOCH_D=3
OVERSOLD=20
OVERBOUGHT=80

# Trend filter — fast/slow EMA stack (defines chart trend direction)
EMA_FAST=21
EMA_SLOW=50
REQUIRE_SLOPE=true    # also require slow EMA sloping in trade direction

# Trend-strength filter (ATR): EMA gap must be >= MIN_TREND_ATR × ATR to trade.
# Higher = stricter (avoids chop), fewer trades. 0.15 is a light filter.
ATR_PERIOD=14
MIN_TREND_ATR=0.15

# Momentum filter: RSI must agree with direction (>50 buy, <50 sell)
USE_RSI=true
RSI_PERIOD=14

# Entry timing (scalp): enter on pullbacks for a better price
#   uptrend  -> BUY  only when %K <= SCALP_BUY_BELOW  (buy the dip)
#   downtrend-> SELL only when %K >= SCALP_SELL_ABOVE (sell the rally)
PULLBACK_ENTRY=true
SCALP_BUY_BELOW=40
SCALP_SELL_ABOVE=60
MAX_EXTENSION_ATR=1.5   # skip entries stretched > this × ATR from the fast EMA

# ── Scalp mode ──────────────────────────────────────────────────────────────
# ON: auto-trade follows the trend with NO SL/TP, closes each trade at
# +$PROFIT_TARGET, then opens a fresh trend trade. (SL/TP settings below are
# ignored while scalp mode is on.)
SCALP_MODE=true
PROFIT_TARGET=2.0     # close a position once it's up this many dollars
POLL_INTERVAL=15      # re-check/re-enter this often (lower = faster re-entry)
MONITOR_INTERVAL=2    # how often profit is checked for the target close
MAX_LOSS=10.0         # emergency close if a trade hits -$this (0 = off)
LOSS_COOLDOWN=30      # seconds to pause entries after a losing close

# Stop Loss — distance in PRICE units (USD for XAUUSD). 0 = disabled.
# (Only used when SCALP_MODE=false)
SL_DISTANCE=3.0    # stop 3 dollars from entry

# Multiple Take-Profit levels (scaling out). Comma-separated distances in USD.
# Each level opens a SEPARATE trade of VOLUME lots, all sharing the same SL.
#   TP_LEVELS=6       -> 1 trade,  TP at $6
#   TP_LEVELS=6,12    -> 2 trades, close at $6 and $12
#   TP_LEVELS=4,8,12  -> 3 trades, close at $4/$8/$12
TP_LEVELS=6,12

# AI analyst (Anthropic Claude) — reads the last hour of candles, confirms/vetoes
# entries by higher-lows / lower-highs structure. Get a key at console.anthropic.com
ANTHROPIC_API_KEY=
AI_ENABLED=false            # set true to require AI agreement before every entry
AI_MODEL=claude-opus-4-8
AI_MIN_CONFIDENCE=60        # veto the trade if Claude's confidence is below this

# Telegram (get token from @BotFather, chat_id from @userinfobot)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# PostgreSQL (docker-compose default — change if using external DB)
DATABASE_URL=postgresql://botuser:botpass@db:5432/tradingbot
