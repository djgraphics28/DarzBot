# Copy this to .env and fill in your values

# Windows VM IP (run `ipconfig` inside the VM, look for VMware/Parallels adapter)
VM_IP=192.168.64.2
VM_PORT=5000

# Trading settings
SYMBOL=XAUUSD
TIMEFRAME=5          # M5
VOLUME=0.01          # lot size
POLL_INTERVAL=60     # seconds between signal checks (match your candle TF)
MONITOR_INTERVAL=5   # seconds between position P&L checks
MAX_POSITIONS=1      # max concurrent open positions (0 = unlimited)

# Stochastic
STOCH_K=14
STOCH_D=3
OVERSOLD=20
OVERBOUGHT=80

# Trend filter — fast/slow EMA stack (defines chart trend direction)
EMA_FAST=21
EMA_SLOW=50
REQUIRE_SLOPE=true   # also require slow EMA sloping in trade direction

# Stop Loss — distance in PRICE units (USD for XAUUSD). 0 = disabled.
SL_DISTANCE=3.0    # stop 3 dollars from entry

# Multiple Take-Profit levels (scaling out). Comma-separated distances in USD.
# Each level opens a SEPARATE trade of VOLUME lots, all sharing the same SL.
#   TP_LEVELS=6       -> 1 trade,  TP at $6
#   TP_LEVELS=6,12    -> 2 trades, close at $6 and $12
#   TP_LEVELS=4,8,12  -> 3 trades, close at $4/$8/$12
TP_LEVELS=6,12

# Telegram (get token from @BotFather, chat_id from @userinfobot)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# PostgreSQL (docker-compose default — change if using external DB)
DATABASE_URL=postgresql://botuser:botpass@db:5432/tradingbot
